# Local data — the SQLite archive is generated at runtime, not committed
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Secrets — never commit API keys
.env
.env.*

# Built static site (generated by `ainews build`) — root output only,
# not the ainews/site/ package
/site/

# OS
.DS_Store
