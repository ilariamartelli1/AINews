# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Local data — the SQLite archive (data/ainews.db) IS committed so the daily
# cloud pipeline persists dedup state + archive across runs. Only ignore the
# transient WAL/journal sidecars.
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/last_run.json

# Secrets — never commit API keys
.env
.env.*

# Built static site (generated by `ainews build`) — root output only,
# not the ainews/site/ package
/site/

# OS
.DS_Store
